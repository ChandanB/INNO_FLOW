48-986a-4cbf-9745-bd33cf8c5ade&quot;,&quot;name&quot;:&quot;Design Structure&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.chainLlm&quot;,&quot;typeVersion&quot;:1.9,&quot;position&quot;:[1840,0],&quot;retryOnFail&quot;:true,&quot;maxTries&quot;:3,&quot;waitBetweenTries&quot;:2000},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;value&quot;:&quot;claude-sonnet-4-20250514&quot;,&quot;mode&quot;:&quot;list&quot;,&quot;cachedResultName&quot;:&quot;Claude Sonnet 4&quot;},&quot;options&quot;:{}},&quot;id&quot;:&quot;977ebcb4-ca6c-4d5a-bf9f-8a35805ab7a1&quot;,&quot;name&quot;:&quot;Design Structure Model&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[1856,224],&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:llm-proxy-anthropic}}&quot;,&quot;name&quot;:&quot;anthropic local llm-proxy&quot;}}},{&quot;parameters&quot;:{&quot;schemaType&quot;:&quot;manual&quot;,&quot;inputSchema&quot;:&quot;{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true,\&quot;properties\&quot;:{\&quot;subtopic_clusters\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;},\&quot;suggested_H2_signals\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;},\&quot;suggested_FAQs\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;},\&quot;competitor_gap_analysis\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true}}}&quot;},&quot;id&quot;:&quot;ccd1b1a0-5325-48ba-944b-e6b4498275bc&quot;,&quot;name&quot;:&quot;Design Structure Parser&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.outputParserStructured&quot;,&quot;typeVersion&quot;:1.2,&quot;position&quot;:[2016,224]},{&quot;parameters&quot;:{&quot;promptType&quot;:&quot;define&quot;,&quot;text&quot;:&quot;=Intent &amp; Keywords: {{ $('Analyze Intent').item.json }}\nContent Structure: {{ JSON.stringify($json) }}\nGap Analysis: {{ $('Gap Analysis').item.json.output }}\nQuery Fanout: {{ $('Query Fanout').item.json.output }}\nCompetitor Content: {{ $('Extract Content').item.json.output.content_analysis }}\nBrand Context: {{ JSON.stringify($('Setup').first().json.brand_context) }}&quot;,&quot;hasOutputParser&quot;:true,&quot;batching&quot;:{}},&quot;id&quot;:&quot;42005d2f-a3bf-460f-87e9-d72ae2e661c5&quot;,&quot;name&quot;:&quot;Plan Elements&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.chainLlm&quot;,&quot;typeVersion&quot;:1.9,&quot;position&quot;:[2192,0]},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;value&quot;:&quot;claude-sonnet-4-20250514&quot;,&quot;mode&quot;:&quot;list&quot;,&quot;cachedResultName&quot;:&quot;Claude Sonnet 4&quot;},&quot;options&quot;:{}},&quot;id&quot;:&quot;020c7a2e-460d-42d9-b212-edc3b010f9ac&quot;,&quot;name&quot;:&quot;Plan Elements Model&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[2208,224],&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:llm-proxy-anthropic}}&quot;,&quot;name&quot;:&quot;anthropic local llm-proxy&quot;}}},{&quot;parameters&quot;:{&quot;schemaType&quot;:&quot;manual&quot;,&quot;inputSchema&quot;:&quot;{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;internal_links\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;},\&quot;external_references\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;},\&quot;required_assets\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true},\&quot;editorial_tone_guidance\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true}},\&quot;additionalProperties\&quot;:true}&quot;},&quot;id&quot;:&quot;d6246d95-7987-429a-a60d-a9825594bce0&quot;,&quot;name&quot;:&quot;Plan Elements Parser&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.outputParserStructured&quot;,&quot;typeVersion&quot;:1.2,&quot;position&quot;:[2384,224]},{&quot;parameters&quot;:{&quot;promptType&quot;:&quot;define&quot;,&quot;text&quot;:&quot;=Gap Analysis: {{ $('Gap Analysis').item.json.output }}\nQuery Fanout: {{ $('Query Fanout').item.json.output }}\nCompetitor Content: {{ $('Extract Content').item.json.output.content_analysis }}\nIntent &amp; Keywords: {{ $('Analyze Intent').item.json.output }}\nContent Structure: {{ $('Design Structure').item.json.output }}\nSupporting Elements: {{ JSON.stringify($json) }}\nBrand Context: {{ JSON.stringify($('Setup').first().json.brand_context) }}&quot;,&quot;hasOutputParser&quot;:true,&quot;messages&quot;:{&quot;messageValues&quot;:[{&quot;message&quot;:&quot;=You are an SEO content brief generator. Your PRIMARY directive is to create brand-differentiated content that reflects the company's unique value proposition and positioning.\n\nCRITICAL: Use the Gap Analysis data to drive differentiation. The gap_analysis contains:\n- topic_coverage_matrix: Shows where competitors are weak and where brand has high expertise match\n- differentiation_angles: Specific approaches that leverage brand strengths\n- content_gaps: User needs that competitors miss that brand can fill\n- recommended_positioning: Overall strategic direction\n\nAlso use Domain Context extensively. The brand_context contains:\n- value_proposition: The brand's unique offering - ALL content must connect to this\n- target_audience: Who the brand serves - tailor content to their specific needs\n- brand_point_of_view: The brand's perspective - infuse this into recommendations\n- competitors: Who they compete against - differentiate from these specifically\n- audience_goals: What their customers want to achieve - address these directly\n\nEDITORIAL GUIDELINES: Educate first, 80% educational / 20% brand-relevant. Avoid sales language. But the 80% educational content should STILL reflect the brand's unique lens and expertise.\n\nOUTPUT (JSON with content_brief object):\n\n1. pitch: {\n   abstract: 2-3 sentences summarizing WHAT this article covers and the value it provides to readers.\n   content_gap_opportunity: 2-3 sentences explaining the SEO opportunity - reference gap_analysis.recommended_positioning and specific differentiation_angles.\n}\n\n2. funnel_stage: {\n   stage: \&quot;top\&quot; | \&quot;middle\&quot; | \&quot;bottom\&quot;,\n   reasoning: Brief explanation based on search intent.\n}\n\n3. target_audience: {role, industry_context, experience_level, pain_points[]}\n\n4. primary_title_suggestions: 3 titles that MUST:\n   - Directly address a differentiation_angle from gap_analysis\n   - Reflect the brand's unique lens (from brand_context.value_proposition)\n   - Appeal specifically to brand_context.target_audience\n   - NOT be generic (avoid \&quot;What is X?\&quot; or \&quot;Complete Guide to X\&quot;)\n\n5. primary_keyword: {keyword, search_volume, keyword_difficulty}\n\n6. secondary_keywords: [{keyword, search_volume, keyword_difficulty}]\n\n7. search_intent_strategy: {primary_intent, intent_evidence[], content_type_recommendation, key_user_goals[]}\n\n8. target_word_count: {\n     min: Minimum word count (competitor avg - 10%),\n     max: Maximum word count (competitor avg + 20%),\n     recommended: Sweet spot (competitor avg + 10%),\n     calculation: \&quot;Based on top 5 competitor average\&quot;\n   }\n\n9. section_guidance: Prioritized content sections with length recommendations\n   {\n     must_include: [\n       {\n         section: \&quot;Section topic that MUST be covered\&quot;,\n         brand_angle: \&quot;How this connects to brand expertise/differentiators\&quot;,\n         suggested_length: \&quot;2-3 paragraphs\&quot; or \&quot;Include 2 subsections\&quot;,\n         why_essential: \&quot;Why this section is required for the topic\&quot;\n       }\n     ],\n     recommended: [\n       {\n         section: \&quot;Section that strengthens the piece\&quot;,\n         brand_angle: \&quot;Brand connection point\&quot;,\n         suggested_length: \&quot;1-2 paragraphs\&quot;,\n         adds_value: \&quot;How this improves comprehensiveness\&quot;\n       }\n     ],\n     optional: [\n       {\n         section: \&quot;Nice-to-have section\&quot;,\n         suggested_length: \&quot;1 paragraph max\&quot;,\n         include_if: \&quot;Word count allows / reader interest\&quot;\n       }\n     ],\n     total_sections_note: \&quot;Aim for 5-7 total sections to stay within word count\&quot;\n   }\n   \n   SECTION GUIDANCE RULES:\n   - must_include: 2-3 sections that are essential for topic coverage\n   - recommended: 2-3 sections that add depth\n   - optional: 1-2 sections only if word count allows\n   - Always include brand_angle for must_include and recommended\n\n10. suggested_H2s: [{\n   heading: H2 title reflecting brand's unique lens,\n   keywords: [],\n   depth_recommendation: \&quot;high\&quot; | \&quot;medium\&quot; | \&quot;standard\&quot;,\n   brand_connection: How this connects to brand value prop AND addresses a gap_analysis.differentiation_angle,\n   sub_sections: [{h3, guidance, reference_note}],\n   section_goal: What this accomplishes\n}] - 5-8 H2s prioritizing topics where gap_analysis shows competitor weakness\n\n11. suggested_FAQs: [{\n   question,\n   answer: Answer demonstrating brand expertise,\n   brand_tie_in: How this addresses a gap_analysis.content_gap\n}]\n12. seo_competitors: [{url, domain, strengths, gaps}] - Reference gap_analysis.topic_coverage_matrix\n\n13. internal_links: ONLY use URLs that appear in the input data (from proprietary insights, source URLs, or SERP data). DO NOT invent or guess URL paths. Include:\n   - URLs from suggested_H2s[].internal_links (verified source domain pages)\n   - URLs from proprietary_insights[].source_url\n   Format: [{target_url, anchor_text_suggestion, relevance_reason}]\n   CRITICAL: If no verified URLs are available, return an empty array. Never make up paths like /blog/topic-name.\n\n14. required_assets: {images:[], videos:[], interactive:[]}\n\n15. seo_notes: Reference gap_analysis.differentiation_angles for unique opportunities\n\n16. editorial_tone_guidance: {voice_pattern, formality_level, content_approach, brand_integration:\&quot;80/20\&quot;}\n\n17. brand_cta_section: Create a compelling CTA section following SEO best practices:\n   {\n     suggested_h2: \&quot;Action-oriented section title (e.g., 'Ready to Transform Your Workflow?')\&quot;,\n     key_points: [\n       \&quot;Bullet point 1: Key benefit or value proposition\&quot;,\n       \&quot;Bullet point 2: Unique differentiator or feature\&quot;,\n       \&quot;Bullet point 3: Social proof or credibility signal\&quot;\n     ],\n     cta_suggestions: [\n       {\n         text: \&quot;Up to 5 words - action verb + benefit (e.g., 'Start Free Trial Today')\&quot;,\n         explanation: \&quot;Why this CTA works - target audience motivation\&quot;\n       },\n       {\n         text: \&quot;Alternative CTA (e.g., 'See Demo Now')\&quot;,\n         explanation: \&quot;Secondary action for different user intent\&quot;\n       }\n     ],\n     placement_note: \&quot;Where to position CTA for maximum impact\&quot;\n   }\n   \n   CTA BEST PRACTICES:\n   - CTA text: MAX 5 words, start with action verb (Get, Start, Try, Discover, Learn)\n   - Be specific: \&quot;Get Free SEO Audit\&quot; beats \&quot;Learn More\&quot;\n   - Create urgency: \&quot;Today\&quot;, \&quot;Now\&quot;, \&quot;Instant\&quot; when appropriate\n   - Match intent: Bottom-funnel = direct action, Top-funnel = soft engagement\n   - key_points: 3-5 compelling bullet points that support the CTA\n   - DO NOT include target_page - let user determine appropriate landing pages\n\n18. gap_analysis_summary: {\n   key_differentiators: Top 3 differentiation angles being leveraged,\n   competitor_weaknesses_addressed: Which gaps this content fills,\n   brand_expertise_areas: Topics where brand has high expertise match\n}\n\n19. priority_score: {value:0-100, calculation:{...}, interpretation}\n\n20. confidence_score: {value:0-1, calculation:{...}, interpretation}\n\n21. metadata: {timestamp, sources[], data_completeness_flags}\n\n22. competitor_titles: Extract top 5 titles from SERP data (serp_data.top_results):\n   - For each item, include ALL fields: {title, url, domain, position, char_count}\n   - The url field is REQUIRED - copy it directly from serp_data.top_results[].url\n   - Example: {\&quot;title\&quot;: \&quot;How to Build...\&quot;, \&quot;url\&quot;: \&quot;https://example.com/article\&quot;, \&quot;domain\&quot;: \&quot;example.com\&quot;, \&quot;position\&quot;: 1, \&quot;char_count\&quot;: 45}\n23. title_char_analysis: {avg_char_count, min_char_count, max_char_count, recommended_range}\n\nGAP ANALYSIS USAGE CHECKLIST:\n□ Title options address specific differentiation_angles\n□ H2s prioritize topics where competitors are weak (coverage_quality = weak/moderate)\n□ H2s focus on areas where brand_expertise_match is high\n□ FAQs address content_gaps.user_need\n□ Depth guidance reflects topic_coverage_matrix\n□ Overall positioning aligns with recommended_positioning\n\nOutput valid JSON only. Start with { and end with }.&quot;}]},&quot;batching&quot;:{}},&quot;id&quot;:&quot;ebbe3046-4e57-4d87-8169-cabe63c8f07c&quot;,&quot;name&quot;:&quot;Assemble Brief&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.chainLlm&quot;,&quot;typeVersion&quot;:1.9,&quot;position&quot;:[2560,0],&quot;retryOnFail&quot;:true,&quot;maxTries&quot;:2,&quot;waitBetweenTries&quot;:1000},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;value&quot;:&quot;claude-opus-4-5-20251101&quot;,&quot;mode&quot;:&quot;list&quot;,&quot;cachedResultName&quot;:&quot;Claude Opus 4.5&quot;},&quot;options&quot;:{}},&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[2576,224],&quot;id&quot;:&quot;f4c5aacb-b903-4825-8ca7-6fcc58a07982&quot;,&quot;name&quot;:&quot;Assemble Brief Model&quot;,&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:llm-proxy-anthropic}}&quot;,&quot;name&quot;:&quot;anthropic local llm-proxy&quot;}}},{&quot;parameters&quot;:{&quot;schemaType&quot;:&quot;manual&quot;,&quot;inputSchema&quot;:&quot;{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true,\&quot;properties\&quot;:{\&quot;output\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true,\&quot;properties\&quot;:{\&quot;content_brief\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;additionalProperties\&quot;:true}}}}}&quot;},&quot;id&quot;:&quot;2efea5b7-7c97-416b-ab66-20c89ffde0e5&quot;,&quot;name&quot;:&quot;Assemble Brief Parser&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.outputParserStructured&quot;,&quot;typeVersion&quot;:1.2,&quot;position&quot;:[2736,224]}],&quot;pinData&quot;:{&quot;Webhook&quot;:[{&quot;json&quot;:{&quot;headers&quot;:{&quot;content-type&quot;:&quot;application/json&quot;,&quot;accept&quot;:&quot;application/json&quot;,&quot;content-length&quot;:&quot;51&quot;,&quot;user-agent&quot;:&quot;node-fetch/1.0 (+https://github.com/bitinn/node-fetch)&quot;,&quot;accept-encoding&quot;:&quot;gzip,deflate&quot;,&quot;host&quot;:&quot;localhost:5678&quot;,&quot;connection&quot;:&quot;keep-alive&quot;},&quot;params&quot;:{},&quot;query&quot;:{&quot;workflowId&quot;:&quot;XqStnC5KeSNhvbWU&quot;},&quot;body&quot;:{&quot;agenticWorkflowRunId&quot;:&quot;69cad789985572878e5405bf&quot;},&quot;webhookUrl&quot;:&quot;http://localhost:5678/webhook/XqStnC5KeSNhvbWU&quot;,&quot;executionMode&quot;:&quot;production&quot;},&quot;pairedItem&quot;:{&quot;item&quot;:0}}]},&quot;connections&quot;:{&quot;Webhook&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Setup&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Setup&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Loop Over URLs&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Loop Over URLs&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Aggregate Pages&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}],[{&quot;node&quot;:&quot;Fetch Page&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Fetch Page&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Extract HTML&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Extract HTML&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Loop Over URLs&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Aggregate Pages&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Extract Content&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Extract Content Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Extract Content&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Extract Content Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Extract Content&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]},&quot;Extract Content&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Gap Analysis&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Gap Analysis Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Gap Analysis&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Gap Analysis Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Gap Analysis&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]},&quot;Gap Analysis&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Query Fanout&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Query Fanout Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Query Fanout&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Query Fanout Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Query Fanout&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]},&quot;Query Fanout&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Analyze Intent&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Analyze Intent Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Analyze Intent&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Analyze Intent Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Analyze Intent&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]},&quot;Analyze Intent&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Design Structure&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Design Structure Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Design Structure&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Design Structure Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Design Structure&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]},&quot;Design Structure&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Plan Elements&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Plan Elements Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Plan Elements&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Plan Elements Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Plan Elements&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]},&quot;Plan Elements&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Assemble Brief&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Assemble Brief Model&quot;:{&quot;ai_languageModel&quot;:[[{&quot;node&quot;:&quot;Assemble Brief&quot;,&quot;type&quot;:&quot;ai_languageModel&quot;,&quot;index&quot;:0}]]},&quot;Assemble Brief Parser&quot;:{&quot;ai_outputParser&quot;:[[{&quot;node&quot;:&quot;Assemble Brief&quot;,&quot;type&quot;:&quot;ai_outputParser&quot;,&quot;index&quot;:0}]]}},&quot;active&quot;:false,&quot;settings&quot;:{&quot;executionOrder&quot;:&quot;v1&quot;,&quot;availableInMCP&quot;:false},&quot;versionId&quot;:&quot;7c5e1d8c-8937-4935-bf2a-6f3313cb6836&quot;,&quot;meta&quot;:{&quot;instanceId&quot;:&quot;f39b414676f47015e1fd88c59ffa2f7cccce458a021c90dc5ea66c9f272b34cd&quot;},&quot;id&quot;:&quot;ruLXux34Ky147n8dekAzr&quot;,&quot;tags&quot;:[]},&quot;fibonacci-hammer&quot;:{&quot;name&quot;:&quot;Fibonacci Hammer&quot;,&quot;nodes&quot;:[{&quot;parameters&quot;:{&quot;options&quot;:{}},&quot;id&quot;:&quot;4b9e12e2-2b71-49da-a2b3-036c230fb5b6&quot;,&quot;name&quot;:&quot;Set Parameters1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.set&quot;,&quot;typeVersion&quot;:3,&quot;position&quot;:[1056,176]},{&quot;parameters&quot;:{&quot;jsCode&quot;:&quot;// === BRANCH 1: FIBONACCI + PRIMES + COLLATZ ===\nconst startTime = Date.now();\n\n// Recursive Fibonacci (intentionally inefficient)\nfunction fibonacci(n) {\n  if (n &lt;= 1) return n;\n  return fibonacci(n - 1) + fibonacci(n - 2);\n}\n\n// Prime Sieve of Eratosthenes\nfunction sieveOfEratosthenes(limit) {\n  const primes = new Array(limit + 1).fill(true);\n  primes[0] = primes[1] = false;\n  for (let i = 2; i * i &lt;= limit; i++) {\n    if (primes[i]) {\n      for (let j = i * i; j &lt;= limit; j += i) {\n        primes[j] = false;\n      }\n    }\n  }\n  return primes.reduce((count, isPrime) =&gt; count + (isPrime ? 1 : 0), 0);\n}\n\n// Trial division prime check\nfunction isPrime(n) {\n  if (n &lt; 2) return false;\n  for (let i = 2; i &lt;= Math.sqrt(n); i++) {\n    if (n % i === 0) return false;\n  }\n  return true;\n}\n\n// Find first N primes\nfunction findFirstNPrimes(n) {\n  const result = [];\n  let candidate = 2;\n  while (result.length &lt; n) {\n    if (isPrime(candidate)) result.push(candidate);\n    candidate++;\n  }\n  return result;\n}\n\n// Collatz sequence length\nfunction collatzLength(n) {\n  let count = 1;\n  while (n !== 1) {\n    n = n % 2 === 0 ? n / 2 : 3 * n + 1;\n    count++;\n  }\n  return count;\n}\n\n// Find longest Collatz under limit\nfunction longestCollatz(limit) {\n  let maxLen = 0;\n  let maxN   = 1;\n  for (let i = 1; i &lt; limit; i++) {\n    const len = collatzLength(i);\n    if (len &gt; maxLen) { maxLen = len; maxN = i; }\n  }\n  return { n: maxN, length: maxLen };\n}\n\nconst fibResult      = fibonacci(38);\nconst primeCount     = sieveOfEratosthenes(500000);\nconst first100Primes = findFirstNPrimes(100);\nconst collatz        = longestCollatz(100000);\n\nreturn [{\n  json: {\n    branch: 'fibonacci-primes',\n    fibResult,\n    primeCount,\n    first10Primes:  first100Primes.slice(0, 10),\n    last10Primes:   first100Primes.slice(-10),\n    longestCollatz: collatz,\n    durationMs:     Date.now() - startTime,\n    timestamp:      new Date().toISOString()\n  }\n}];&quot;},&quot;id&quot;:&quot;795daf23-14b5-4692-b19f-94f15770dca0&quot;,&quot;name&quot;:&quot;CPU Work - Math &amp; Primes1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.code&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[1296,32]},{&quot;parameters&quot;:{&quot;jsCode&quot;:&quot;// === BRANCH 2: MATRIX OPERATIONS ===\nconst startTime = Date.now();\n\n// Matrix multiply O(n^3)\nfunction matrixMultiply(size) {\n  const a = Array.from({ length: size }, () =&gt;\n    Array.from({ length: size }, () =&gt; Math.random())\n  );\n  const b = Array.from({ length: size }, () =&gt;\n    Array.from({ length: size }, () =&gt; Math.random())\n  );\n  const result = Array.from({ length: size }, () =&gt;\n    new Array(size).fill(0)\n  );\n  for (let i = 0; i &lt; size; i++) {\n    for (let j = 0; j &lt; size; j++) {\n      for (let k = 0; k &lt; size; k++) {\n        result[i][j] += a[i][k] * b[k][j];\n      }\n    }\n  }\n  return result;\n}\n\n// Matrix transpose\nfunction matrixTranspose(m) {\n  return m[0].map((_, col) =&gt; m.map(row =&gt; row[col]));\n}\n\n// Dot product\nfunction dotProduct(a, b) {\n  return a.reduce((sum, val, i) =&gt; sum + val * b[i], 0);\n}\n\n// Benchmark multiple sizes\nconst benchmarks = [];\nfor (const size of [80, 120, 160]) {\n  const t          = Date.now();\n  const product    = matrixMultiply(size);\n  const transposed = matrixTranspose(product);\n  const dp         = dotProduct(product[0], transposed[0]);\n  benchmarks.push({\n    size,\n    durationMs:  Date.now() - t,\n    sampleValue: product[0][0],\n    dotProduct:  dp\n  });\n}\n\n// Vector stress test\nfunction vectorStress(dimensions, iterations) {\n  let result = 0;\n  for (let i = 0; i &lt; iterations; i++) {\n    const v1 = Array.from({ length: dimensions }, () =&gt; Math.random());\n    const v2 = Array.from({ length: dimensions }, () =&gt; Math.random());\n    result  += dotProduct(v1, v2);\n  }\n  return result;\n}\n\nconst vectorResult = vectorStress(500, 300);\n\nreturn [{\n  json: {\n    branch:            'matrix-ops',\n    matrixBenchmarks:  benchmarks,\n    vectorStressResult: vectorResult,\n    totalDurationMs:   Date.now() - startTime,\n    timestamp:         new Date().toISOString()\n  }\n}];&quot;},&quot;id&quot;:&quot;27ef1747-b6bf-425b-9184-f84381a9ec90&quot;,&quot;name&quot;:&quot;CPU Work - Matrix Ops1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.code&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[1296,240]},{&quot;parameters&quot;:{&quot;jsCode&quot;:&quot;// === BRANCH 3: SORTING + REGEX + STRING OPS ===\nconst startTime = Date.now();\n\n// Bubble sort O(n^2) intentionally slow\nfunction bubbleSort(arr) {\n  const a = [...arr];\n  for (let i = 0; i &lt; a.length; i++) {\n    for (let j = 0; j &lt; a.length - i - 1; j++) {\n      if (a[j] &gt; a[j + 1]) {\n        const tmp = a[j];\n        a[j]      = a[j + 1];\n        a[j + 1]  = tmp;\n      }\n    }\n  }\n  return a;\n}\n\n// Merge sort\nfunction mergeSort(arr) {\n  if (arr.length &lt;= 1) return arr;\n  const mid   = Math.floor(arr.length / 2);\n  const left  = mergeSort(arr.slice(0, mid));\n  const right = mergeSort(arr.slice(mid));\n  const out   = [];\n  let l = 0, r = 0;\n  while (l &lt; left.length &amp;&amp; r &lt; right.length) {\n    if (left[l] &lt;= right[r]) out.push(left[l++]);\n    else out.push(right[r++]);\n  }\n  return [...out, ...left.slice(l), ...right.slice(r)];\n}\n\n// Quicksort\nfunction quickSort(arr) {\n  if (arr.length &lt;= 1) return arr;\n  const pivot  = arr[Math.floor(arr.length / 2)];\n  const left   = arr.filter(x =&gt; x &lt; pivot);\n  const middle = arr.filter(x =&gt; x === pivot);\n  const right  = arr.filter(x =&gt; x &gt; pivot);\n  return [...quickSort(left), ...middle, ...quickSort(right)];\n}\n\nconst smallArr = Array.from({ length: 3000  }, () =&gt; Math.random());\nconst medArr   = Array.from({ length: 30000 }, () =&gt; Math.random());\nconst largeArr = Array.from({ length: 100000}, () =&gt; Math.random());\n\nconst tBubble  = Date.now();\nbubbleSort(smallArr);\nconst bubbleMs = Date.now() - tBubble;\n\nconst tMerge   = Date.now();\nmergeSort(medArr);\nconst mergeMs  = Date.now() - tMerge;\n\nconst tQuick   = Date.now();\nquickSort([...medArr]);\nconst quickMs  = Date.now() - tQuick;\n\nconst tNative  = Date.now();\nlargeArr.sort((a, b) =&gt; a - b);\nconst nativeMs = Date.now() - tNative;\n\n// Regex torture on large generated string\nconst bigText = Array.from({ length: 15000 }, () =&gt;\n  Math.random().toString(36) + ' ' + Math.random().toString(36)\n).join('\\n');\n\nconst regexResults = [\n  { name: 'words',    count: (bigText.match(/[a-z]{3,}/g)      || []).length },\n  { name: 'numbers',  count: (bigText.match(/\\d+\\.\\d+/g)       || []).length },\n  { name: 'hex',      count: (bigText.match(/[0-9a-f]{8}/g)    || []).length },\n  { name: 'alphaNum', count: (bigText.match(/[a-zA-Z0-9]{6}/g) || []).length },\n  { name: 'mixed',    count: (bigText.match(/[a-z]{2}\\d{2}/g)  || []).length }\n];\n\n// String builder and manipulation\nconst tStr  = Date.now();\nconst parts = [];\nfor (let i = 0; i &lt; 50000; i++) {\n  parts.push(Math.random().toString(36).substr(2));\n}\nconst bigStr     = parts.join('-');\nconst reversed   = bigStr.split('').reverse().join('');\nconst upperCount = (reversed.match(/[A-Z]/g) || []).length;\nconst strMs      = Date.now() - tStr;\n\nreturn [{\n  json: {\n    branch: 'sort-regex-string',\n    sortBenchmarks: {\n      bubbleSort: { size: smallArr.length, durationMs: bubbleMs },\n      mergeSort:  { size: medArr.length,   durationMs: mergeMs  },\n      quickSort:  { size: medArr.length,   durationMs: quickMs  },\n      nativeSort: { size: largeArr.length, durationMs: nativeMs }\n    },\n    regexResults,\n    stringOps: {\n      totalChars:     bigStr.length,\n      upperCaseCount: upperCount,\n      durationMs:     strMs\n    },\n    totalDurationMs: Date.now() - startTime,\n    timestamp:       new Date().toISOString()\n  }\n}];&quot;},&quot;id&quot;:&quot;4bff53f4-e6c0-4855-95d4-1bccaaacc065&quot;,&quot;name&quot;:&quot;CPU Work - Sort &amp; String1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.code&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[1296,432]},{&quot;parameters&quot;:{&quot;jsCode&quot;:&quot;// === BRANCH 4: JSON + OBJECT + MAP/SET STRESS ===\nconst startTime = Date.now();\n\n// Deep nested object builder\nfunction buildDeepObject(depth, breadth) {\n  if (depth === 0) {\n    return {\n      value:  Math.random(),\n      label:  Math.random().toString(36).substr(2, 8),\n      active: Math.random() &gt; 0.5,\n      scores: Array.from({ length: 10 }, () =&gt; Math.random())\n    };\n  }\n  const obj = {};\n  for (let i = 0; i &lt; breadth; i++) {\n    obj[`node_${depth}_${i}`] = buildDeepObject(depth - 1, breadth);\n  }\n  return obj;\n}\n\n// Count all leaf nodes in object tree\nfunction countLeafNodes(obj) {\n  if (typeof obj !== 'object' || obj === null) return 1;\n  return Object.values(obj).reduce((sum, v) =&gt; sum + countLeafNodes(v), 0);\n}\n\n// JSON round trip stress\nfunction jsonRoundTrip(obj, times) {\n  let result = obj;\n  for (let i = 0; i &lt; times; i++) {\n    result = JSON.parse(JSON.stringify(result));\n  }\n  return result;\n}\n\n// Array of objects: filter + sort + reduce + map\nfunction arrayObjectStress(size) {\n  const arr = Array.from({ length: size }, (_, i) =&gt; ({\n    id:     i,\n    value:  Math.random() * 1000,\n    label:  Math.random().toString(36).substr(2, 6),\n    active: Math.random() &gt; 0.5\n  }));\n  const filtered = arr.filter(x =&gt; x.active &amp;&amp; x.value &gt; 500);\n  const sorted   = filtered.sort((a, b) =&gt; b.value - a.value);\n  const total    = sorted.reduce((sum, x) =&gt; sum + x.value, 0);\n  const mapped   = sorted.slice(0, 10).map(x =&gt; ({\n    ...x,\n    normalised: x.value / total\n  }));\n  return {\n    originalSize: arr.length,\n    filteredSize: filtered.length,\n    total:        Math.round(total),\n    top10:        mapped.length\n  };\n}\n\n// Map and Set stress test\nfunction mapSetStress(size) {\n  const map = new Map();\n  const set = new Set();\n  for (let i = 0; i &lt; size; i++) {\n    const key = Math.random().toString(36).substr(2, 6);\n    map.set(key, { index: i, value: Math.random() });\n    set.add(key);\n  }\n  let lookups = 0;\n  for (const key of set) {\n    if (map.has(key)) lookups++;\n  }\n  return { mapSize: map.size, setSize: set.size, lookups };\n}\n\nconst tDeep     = Date.now();\nconst deepObj   = buildDeepObject(4, 4);\nconst leafCount = countLeafNodes(deepObj);\nconst deepMs    = Date.now() - tDeep;\n\nconst tJson     = Date.now();\njsonRoundTrip(deepObj, 20);\nconst jsonMs    = Date.now() - tJson;\n\nconst arrayResult = arrayObjectStress(50000);\nconst mapResult   = mapSetStress(100000);\n\nreturn [{\n  json: {\n    branch: 'json-object-stress',\n    deepObject: {\n      leafNodes:  leafCount,\n      buildMs:    deepMs\n    },\n    jsonRoundTrips: {\n      times:      20,\n      durationMs: jsonMs\n    },\n    arrayObjectResult: arrayResult,\n    mapSetResult:      mapResult,\n    totalDurationMs:   Date.now() - startTime,\n    timestamp:         new Date().toISOString()\n  }\n}];&quot;},&quot;id&quot;:&quot;b276679a-af51-44e7-8cf9-bcaadff4598f&quot;,&quot;name&quot;:&quot;CPU Work - JSON &amp; Objects1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.code&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[1296,640]},{&quot;parameters&quot;:{},&quot;id&quot;:&quot;2f4299ad-7d8c-4d03-a3e2-249cb297b272&quot;,&quot;name&quot;:&quot;Merge Results1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.merge&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[1568,336]},{&quot;parameters&quot;:{&quot;jsCode&quot;:&quot;// === FINAL AGGREGATION - fully sandbox safe ===\nconst items = $input.all();\n\nconst branchSummary = items.map(item =&gt; ({\n  branch:     item.json.branch,\n  durationMs: item.json.durationMs || item.json.totalDurationMs || 0\n}));\n\nconst totalCpuMs = branchSummary.reduce((sum, b) =&gt; sum + b.durationMs, 0);\nconst sorted     = [...branchSummary].sort((a, b) =&gt; b.durationMs - a.durationMs);\n\nreturn [{\n  json: {\n    status:        'complete',\n    totalBranches: items.length,\n    totalCpuMs,\n    avgBranchMs:   Math.round(totalCpuMs / items.length),\n    slowestBranch: sorted[0],\n    fastestBranch: sorted[sorted.length - 1],\n    allBranches:   branchSummary,\n    completedAt:   new Date().toISOString(),\n    summary:       `Hammer complete. ${items.length} parallel branches. Total CPU time: ${totalCpuMs}ms`\n  }\n}];&quot;},&quot;id&quot;:&quot;d8a5120c-6dbf-47e7-bc46-ab18434fe7e4&quot;,&quot;name&quot;:&quot;Aggregate Results1&quot;,&quot;type&quot;:&quot;n8n-nodes-base.code&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[1776,336]},{&quot;parameters&quot;:{&quot;httpMethod&quot;:&quot;POST&quot;,&quot;path&quot;:&quot;={{ $workflow.id }}&quot;,&quot;responseMode&quot;:&quot;responseNode&quot;,&quot;options&quot;:{}},&quot;type&quot;:&quot;n8n-nodes-base.webhook&quot;,&quot;typeVersion&quot;:2.1,&quot;position&quot;:[864,176],&quot;id&quot;:&quot;e793ead5-bb6a-4c10-8b97-2db61438b13e&quot;,&quot;name&quot;:&quot;Webhook&quot;,&quot;webhookId&quot;:&quot;cfdcc08f-535e-462d-9b4c-6b46ff867597&quot;},{&quot;parameters&quot;:{&quot;respondWith&quot;:&quot;json&quot;,&quot;responseBody&quot;:&quot;={{ JSON.stringify($json) }}&quot;,&quot;options&quot;:{}},&quot;id&quot;:&quot;e88a22e0-1de3-4c88-a210-2bc01b3ce376&quot;,&quot;name&quot;:&quot;Respond to Webhook&quot;,&quot;type&quot;:&quot;n8n-nodes-base.respondToWebhook&quot;,&quot;typeVersion&quot;:1,&quot;position&quot;:[2000,336]}],&quot;pinData&quot;:{},&quot;connections&quot;:{&quot;Set Parameters1&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;CPU Work - Math &amp; Primes1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0},{&quot;node&quot;:&quot;CPU Work - Matrix Ops1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0},{&quot;node&quot;:&quot;CPU Work - Sort &amp; String1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0},{&quot;node&quot;:&quot;CPU Work - JSON &amp; Objects1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;CPU Work - Math &amp; Primes1&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Merge Results1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;CPU Work - Matrix Ops1&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Merge Results1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:1}]]},&quot;Merge Results1&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Aggregate Results1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;Aggregate Results1&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Respond to Webhook&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]},&quot;CPU Work - Sort &amp; String1&quot;:{&quot;main&quot;:[[]]},&quot;CPU Work - JSON &amp; Objects1&quot;:{&quot;main&quot;:[[]]},&quot;Webhook&quot;:{&quot;main&quot;:[[{&quot;node&quot;:&quot;Set Parameters1&quot;,&quot;type&quot;:&quot;main&quot;,&quot;index&quot;:0}]]}},&quot;active&quot;:true,&quot;settings&quot;:{&quot;executionOrder&quot;:&quot;v1&quot;,&quot;availableInMCP&quot;:false,&quot;callerPolicy&quot;:&quot;workflowsFromSameOwner&quot;},&quot;versionId&quot;:&quot;bfacb03f-d6ff-4e03-95e5-ce3947ca9a08&quot;,&quot;meta&quot;:{&quot;instanceId&quot;:&quot;f39b414676f47015e1fd88c59ffa2f7cccce458a021c90dc5ea66c9f272b34cd&quot;},&quot;id&quot;:&quot;ZFfp2G9WDJCAJ7fL&quot;,&quot;tags&quot;:[]},&quot;credentials-demo&quot;:{&quot;name&quot;:&quot;Credentials Demo&quot;,&quot;nodes&quot;:[{&quot;parameters&quot;:{&quot;httpMethod&quot;:&quot;POST&quot;,&quot;path&quot;:&quot;={{ $workflow.id }}&quot;,&quot;options&quot;:{}},&quot;type&quot;:&quot;n8n-nodes-base.webhook&quot;,&quot;typeVersion&quot;:2.1,&quot;position&quot;:[0,0],&quot;id&quot;:&quot;77d2c610-857e-4d69-b44f-01193eae3366&quot;,&quot;name&quot;:&quot;Webhook&quot;,&quot;webhookId&quot;:&quot;08bda7bc-0e5b-4585-8c3a-d78c4defafa0&quot;},{&quot;parameters&quot;:{&quot;url&quot;:&quot;https://api.openweathermap.org/data/2.5/weather&quot;,&quot;authentication&quot;:&quot;genericCredentialType&quot;,&quot;genericAuthType&quot;:&quot;httpQueryAuth&quot;,&quot;sendQuery&quot;:true,&quot;queryParameters&quot;:{&quot;parameters&quot;:[{&quot;name&quot;:&quot;q&quot;,&quot;value&quot;:&quot;San Francisco&quot;},{&quot;name&quot;:&quot;units&quot;,&quot;value&quot;:&quot;imperial&quot;}]},&quot;options&quot;:{}},&quot;type&quot;:&quot;n8n-nodes-base.httpRequest&quot;,&quot;typeVersion&quot;:4.3,&quot;position&quot;:[208,0],&quot;id&quot;:&quot;931df33f-601d-4ef2-a248-95f078e4a746&quot;,&quot;name&quot;:&quot;HTTP Request&quot;,&quot;credentials&quot;:{&quot;httpQueryAuth&quot;:{&quot;id&quot;:&quot;{{credential:weather-api}}&quot;,&quot;name&quot;:&quot;Query Auth account&quot;}}},{&quot;parameters&quot;:{},&quot;type&quot;:&quot;n8n-nodes-base.noOp&quot;,&quot;typeVersion&quot;:1,&quot;position&quot;:[416,