;},{&quot;parameters&quot;:{&quot;assignments&quot;:{&quot;assignments&quot;:[{&quot;id&quot;:&quot;3c7c1024-ebb9-4a7f-8779-0e93847650a8&quot;,&quot;name&quot;:&quot;siteId&quot;,&quot;value&quot;:&quot;={{ $vars.siteId }}&quot;,&quot;type&quot;:&quot;string&quot;},{&quot;id&quot;:&quot;b08dffa4-71f5-451f-80cc-64318b326d06&quot;,&quot;name&quot;:&quot;userId&quot;,&quot;value&quot;:&quot;={{ $vars.userId }}&quot;,&quot;type&quot;:&quot;string&quot;}]},&quot;options&quot;:{}},&quot;type&quot;:&quot;n8n-nodes-base.set&quot;,&quot;typeVersion&quot;:3.4,&quot;position&quot;:[208,0],&quot;id&quot;:&quot;8ae521a7-e667-4bd6-b3c3-831e523dbc89&quot;,&quot;name&quot;:&quot;Edit Fields&quot;},{&quot;parameters&quot;:{&quot;promptType&quot;:&quot;define&quot;,&quot;text&quot;:&quot;Using the Webflow MCP, return my current site name. After receiving the tool result, do not call any more tools.&quot;,&quot;options&quot;:{}},&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.agent&quot;,&quot;typeVersion&quot;:3.1,&quot;position&quot;:[416,0],&quot;id&quot;:&quot;bd3317fb-1c45-413b-91d4-d9608cda78c5&quot;,&quot;name&quot;:&quot;AI Agent&quot;},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;mode&quot;:&quot;list&quot;,&quot;value&quot;:&quot;claude-sonnet-4-5-20250929&quot;,&quot;cachedResultName&quot;:&quot;Claude Sonnet 4.5&quot;},&quot;options&quot;:{}},&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[416,208],&quot;id&quot;:&quot;1b11c7e9-8105-4a23-a2e6-9587553fa552&quot;,&quot;name&quot;:&quot;Anthropic Chat Model&quot;,&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:anthropic-api}}&quot;,&quot;name&quot;:&quot;Anthropic account&quot;}}},{&quot;parameters&quot;:{&quot;endpointUrl&quot;:&quot;={{ $vars.mcpServerUrl }}&quot;,&quot;authentication&quot;:&quot;multipleHeadersAuth&quot;,&quot;options&quot;:{}},&quot;type&quot;:&quot;@n8n/n8n-nodes-langcha