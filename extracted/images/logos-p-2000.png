ot;:&quot;Content Brief Generator&quot;,&quot;nodes&quot;:[{&quot;parameters&quot;:{&quot;httpMethod&quot;:&quot;POST&quot;,&quot;path&quot;:&quot;={{ $workflow.id }}&quot;,&quot;options&quot;:{}},&quot;type&quot;:&quot;n8n-nodes-base.webhook&quot;,&quot;typeVersion&quot;:2.1,&quot;position&quot;:[-720,208],&quot;id&quot;:&quot;8ba4f27e-b5aa-48a0-a448-b76201d74c0b&quot;,&quot;name&quot;:&quot;Webhook&quot;,&quot;webhookId&quot;:&quot;0808464e-9980-4610-b79d-1d50abec3031&quot;},{&quot;parameters&quot;:{&quot;jsCode&quot;:&quot;const split = (s) =&gt; s.split(',').map(s =&gt; s.trim()).filter(Boolean);\n\nconst config = {\n  domain: $vars.domain,\n  prompt: $vars.prompt,\n  brand_context: {\n    brand_name: $vars.brandName,\n    brand_domain: $vars.domain,\n    brand_description: $vars.brandDescription,\n    value_proposition: $vars.valueProposition,\n    competitors: split($vars.competitors),\n    target_audience: $vars.targetAudience,\n    audience_goals: split($vars.audienceGoals),\n    tone_of_voice: $vars.toneOfVoice,\n    resource_urls: split($vars.resourceUrls)\n  },\n  citations: split($vars.citations)\n};\n\nreturn config.citations.map(url =&gt; ({ json: { url, ...config } }));&quot;},&quot;id&quot;:&quot;4e445ad1-1ed0-46d7-b65e-0f39156b2d27&quot;,&quot;name&quot;:&quot;Setup&quot;,&quot;type&quot;:&quot;n8n-nodes-base.code&quot;,&quot;typeVersion&quot;:2,&quot;position&quot;:[-480,208]},{&quot;parameters&quot;:{&quot;options&quot;:{}},&quot;id&quot;:&quot;4bc4c0e0-fd5b-48ee-a62e-f97e2397846f&quot;,&quot;name&quot;:&quot;Loop Over URLs&quot;,&quot;type&quot;:&quot;n8n-nodes-base.splitInBatches&quot;,&quot;typeVersion&quot;:3,&quot;position&quot;:[-240,208]},{&quot;parameters&quot;:{&quot;url&quot;:&quot;={{ $json.url }}&quot;,&quot;sendHeaders&quot;:true,&quot;headerParameters&quot;:{&quot;parameters&quot;:[{&quot;name&quot;:&quot;User-Agent&quot;,&quot;value&quot;:&quot;Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36&quot;},{&quot;name&quot;:&quot;Accept&quot;,&quot;value&quot;:&quot;text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8&quot;},{&quot;name&quot;:&quot;Accept-Language&quot;,&quot;value&quot;:&quot;en-US,en;q=0.9&quot;},{&quot;name&quot;:&quot;Referer&quot;,&quot;value&quot;:&quot;https://www.google.com/&quot;}]},&quot;options&quot;:{&quot;allowUnauthorizedCerts&quot;:true,&quot;response&quot;:{&quot;response&quot;:{&quot;responseFormat&quot;:&quot;text&quot;}},&quot;timeout&quot;:30000}},&quot;id&quot;:&quot;d9a978c9-6165-43e5-a73c-2416911b93dc&quot;,&quot;name&quot;:&quot;Fetch Page&quot;,&quot;type&quot;:&quot;n8n-nodes-base.httpRequest&quot;,&quot;typeVersion&quot;:4.3,&quot;position&quot;:[0,208],&quot;retryOnFail&quot;:true,&quot;maxTries&quot;:2,&quot;onError&quot;:&quot;continueRegularOutput&quot;},{&quot;parameters&quot;:{&quot;operation&quot;:&quot;extractHtmlContent&quot;,&quot;extractionValues&quot;:{&quot;values&quot;:[{&quot;key&quot;:&quot;content&quot;,&quot;cssSelector&quot;:&quot;h1, h2, h3, h4, p, li, blockquote, script[type='application/ld+json']&quot;,&quot;returnArray&quot;:true}]},&quot;options&quot;:{}},&quot;type&quot;:&quot;n8n-nodes-base.html&quot;,&quot;typeVersion&quot;:1.2,&quot;position&quot;:[208,208],&quot;id&quot;:&quot;d6110d7d-ee68-499d-95d2-4419bf502d62&quot;,&quot;name&quot;:&quot;Extract HTML&quot;,&quot;onError&quot;:&quot;continueRegularOutput&quot;},{&quot;parameters&quot;:{&quot;aggregate&quot;:&quot;aggregateAllItemData&quot;,&quot;options&quot;:{}},&quot;id&quot;:&quot;49b56c17-7c30-42d8-91e1-525775c7ffaa&quot;,&quot;name&quot;:&quot;Aggregate Pages&quot;,&quot;type&quot;:&quot;n8n-nodes-base.aggregate&quot;,&quot;typeVersion&quot;:1,&quot;position&quot;:[0,0]},{&quot;parameters&quot;:{&quot;promptType&quot;:&quot;define&quot;,&quot;text&quot;:&quot;={{ JSON.stringify($json.data) }}&quot;,&quot;hasOutputParser&quot;:true,&quot;messages&quot;:{&quot;messageValues&quot;:[{&quot;message&quot;:&quot;You are a JSON extraction specialist. You analyze HTML and return structured JSON.\n\nABSOLUTE REQUIREMENTS - FAILURE TO COMPLY WILL CAUSE SYSTEM ERRORS:\n- Output ONLY raw JSON - no text before or after\n- DO NOT wrap in markdown code blocks (no ```json or ```)\n- DO NOT add any explanation or commentary\n- Your response must start with the character { and end with }\n- Your response must be valid JSON parseable by JSON.parse()\n\nEXPECTED OUTPUT FORMAT:\n{\&quot;content_analysis\&quot;:{\&quot;competitor_pages\&quot;:[{\&quot;url\&quot;:\&quot;page-url\&quot;,\&quot;h1\&quot;:\&quot;heading\&quot;,\&quot;h2_tags\&quot;:[\&quot;h2-1\&quot;,\&quot;h2-2\&quot;],\&quot;h3_tags\&quot;:[\&quot;h3-1\&quot;],\&quot;word_count\&quot;:1500,\&quot;has_article_schema\&quot;:false,\&quot;has_product_schema\&quot;:false,\&quot;content_sections\&quot;:[\&quot;section1\&quot;],\&quot;summary\&quot;:\&quot;Brief summary\&quot;}]}}\n\nExtract from the HTML:\n- url: The page URL (from any canonical or og:url meta tag, or use \&quot;unknown\&quot;)\n- h1: The main H1 heading text\n- h2_tags: Array of all H2 heading texts\n- h3_tags: Array of all H3 heading texts  \n- word_count: Estimated word count of main content (integer)\n- has_article_schema: true if Article schema markup found, false otherwise\n- has_product_schema: true if Product schema markup found, false otherwise\n- content_sections: Array of main topic/section names\n- summary: 2-3 sentence summary of the content\n\nRemember: RAW JSON ONLY. No markdown. No explanation. Start with { end with }&quot;}]},&quot;batching&quot;:{}},&quot;id&quot;:&quot;fe6a3809-d6f1-49a6-bfa1-81eb7a7aa32e&quot;,&quot;name&quot;:&quot;Extract Content&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.chainLlm&quot;,&quot;typeVersion&quot;:1.9,&quot;position&quot;:[400,0],&quot;retryOnFail&quot;:true,&quot;maxTries&quot;:2,&quot;waitBetweenTries&quot;:1000},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;mode&quot;:&quot;list&quot;,&quot;value&quot;:&quot;claude-sonnet-4-5-20250929&quot;,&quot;cachedResultName&quot;:&quot;Claude Sonnet 4.5&quot;},&quot;options&quot;:{}},&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[416,224],&quot;id&quot;:&quot;033da1ee-9503-4b47-ae5e-a6e048312eaf&quot;,&quot;name&quot;:&quot;Extract Content Model&quot;,&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:llm-proxy-anthropic}}&quot;,&quot;name&quot;:&quot;anthropic local llm-proxy&quot;}}},{&quot;parameters&quot;:{&quot;schemaType&quot;:&quot;manual&quot;,&quot;inputSchema&quot;:&quot;{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;content_analysis\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;competitor_pages\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;}},\&quot;additionalProperties\&quot;:true}},\&quot;additionalProperties\&quot;:true}&quot;},&quot;id&quot;:&quot;928dad9a-3bc2-4354-be5e-921e4849fedb&quot;,&quot;name&quot;:&quot;Extract Content Parser&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.outputParserStructured&quot;,&quot;typeVersion&quot;:1.2,&quot;position&quot;:[576,224]},{&quot;parameters&quot;:{&quot;promptType&quot;:&quot;define&quot;,&quot;text&quot;:&quot;=Competitor Analysis: {{ JSON.stringify($json.output.content_analysis) }}\nBrand Context: {{ JSON.stringify($('Setup').first().json.brand_context) }}\nTarget Domain: {{ $('Setup').first().json.domain }}\nPrompt: {{ $('Setup').first().json.prompt }}&quot;,&quot;hasOutputParser&quot;:true,&quot;messages&quot;:{&quot;messageValues&quot;:[{&quot;message&quot;:&quot;Return ONLY the raw JSON object. Do not include any explanation, markdown, XML tags, or tool calls. Your entire response must be valid JSON starting with { and ending with }.&quot;}]},&quot;batching&quot;:{}},&quot;id&quot;:&quot;810fe76b-2d3b-4c01-9ecf-a01bf6c92b02&quot;,&quot;name&quot;:&quot;Gap Analysis&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.chainLlm&quot;,&quot;typeVersion&quot;:1.9,&quot;position&quot;:[752,0]},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;mode&quot;:&quot;list&quot;,&quot;value&quot;:&quot;claude-sonnet-4-20250514&quot;},&quot;options&quot;:{&quot;maxTokensToSample&quot;:4096,&quot;temperature&quot;:0.3}},&quot;id&quot;:&quot;e47aa480-f880-480d-bd2a-683179de9d5d&quot;,&quot;name&quot;:&quot;Gap Analysis Model&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[768,224],&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:llm-proxy-anthropic}}&quot;,&quot;name&quot;:&quot;anthropic local llm-proxy&quot;}}},{&quot;parameters&quot;:{&quot;schemaType&quot;:&quot;manual&quot;,&quot;inputSchema&quot;:&quot;{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;gap_analysis\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;topic_coverage_matrix\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;,\&quot;items\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;topic\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;},\&quot;competitors_covering\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;,\&quot;items\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;}},\&quot;coverage_quality\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;,\&quot;enum\&quot;:[\&quot;weak\&quot;,\&quot;moderate\&quot;,\&quot;strong\&quot;]},\&quot;brand_opportunity\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;},\&quot;brand_expertise_match\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;,\&quot;enum\&quot;:[\&quot;high\&quot;,\&quot;medium\&quot;,\&quot;low\&quot;]}}}},\&quot;differentiation_angles\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;,\&quot;items\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;angle\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;},\&quot;why_brand_wins\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;},\&quot;competitor_weakness\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;}}}},\&quot;content_gaps\&quot;:{\&quot;type\&quot;:\&quot;array\&quot;,\&quot;items\&quot;:{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&quot;gap\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;},\&quot;user_need\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;},\&quot;brand_capability\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;}}}},\&quot;recommended_positioning\&quot;:{\&quot;type\&quot;:\&quot;string\&quot;}}}},\&quot;additionalProperties\&quot;:true}&quot;},&quot;id&quot;:&quot;cb605f95-4fa7-455b-8f77-039de77e9bce&quot;,&quot;name&quot;:&quot;Gap Analysis Parser&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.outputParserStructured&quot;,&quot;typeVersion&quot;:1.2,&quot;position&quot;:[944,224]},{&quot;parameters&quot;:{&quot;promptType&quot;:&quot;define&quot;,&quot;text&quot;:&quot;=Prompt: {{ $('Setup').first().json.prompt }}\nCitations: {{ JSON.stringify($('Setup').first().json.citations) }}&quot;,&quot;hasOutputParser&quot;:true,&quot;messages&quot;:{&quot;messageValues&quot;:[{&quot;message&quot;:&quot;=You are simulating ChatGPT's query fanout behavior. Given a prompt, generate the related questions and sub-queries that ChatGPT would internally consider when answering.\n\nThink like an LLM: What clarifying questions would you ask? What related concepts would you explore? What angles would you cover?\n\nYour goal is to identify the semantic \&quot;fanout\&quot; - the queries that ChatGPT's retrieval and reasoning would expand to when a user asks about this topic. These represent what 85% of LLM traffic (ChatGPT users) would be exploring.\n\nIMPORTANT: Return ONLY valid JSON with this exact structure:\n\n{\n  \&quot;query_fanouts\&quot;: [\n    {\n      \&quot;query\&quot;: \&quot;The related question or sub-query\&quot;,\n      \&quot;intent\&quot;: \&quot;informational|comparison|how-to|definition|example\&quot;,\n      \&quot;angle\&quot;: \&quot;What specific angle this addresses\&quot;,\n      \&quot;h2_potential\&quot;: true,\n      \&quot;priority\&quot;: 8\n    }\n  ],\n  \&quot;thematic_clusters\&quot;: [\n    {\n      \&quot;theme\&quot;: \&quot;Cluster name\&quot;,\n      \&quot;queries\&quot;: [\&quot;query1\&quot;, \&quot;query2\&quot;],\n      \&quot;suggested_h2\&quot;: \&quot;Potential H2 heading (5-12 words)\&quot;\n    }\n  ]\n}\n\nGenerate 10-15 query fanouts that represent what an LLM would explore to comprehensively answer the prompt. Focus on:\n- Clarifying questions users might have\n- Related concepts that provide context\n- Common use cases and examples\n- Comparisons and alternatives\n- Practical applications\n\nSort by priority (10 = highest) based on how central the query is to the main topic.&quot;}]},&quot;batching&quot;:{}},&quot;id&quot;:&quot;7af7ea40-9309-468e-bcf4-caaf262bba33&quot;,&quot;name&quot;:&quot;Query Fanout&quot;,&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.chainLlm&quot;,&quot;typeVersion&quot;:1.9,&quot;position&quot;:[1120,0],&quot;retryOnFail&quot;:true},{&quot;parameters&quot;:{&quot;model&quot;:{&quot;__rl&quot;:true,&quot;mode&quot;:&quot;list&quot;,&quot;value&quot;:&quot;claude-sonnet-4-5-20250929&quot;,&quot;cachedResultName&quot;:&quot;Claude Sonnet 4.5&quot;},&quot;options&quot;:{}},&quot;type&quot;:&quot;@n8n/n8n-nodes-langchain.lmChatAnthropic&quot;,&quot;typeVersion&quot;:1.3,&quot;position&quot;:[1136,224],&quot;id&quot;:&quot;4799d512-fbd1-41c1-8b44-26942760375a&quot;,&quot;name&quot;:&quot;Query Fanout Model&quot;,&quot;credentials&quot;:{&quot;anthropicApi&quot;:{&quot;id&quot;:&quot;{{credential:llm-proxy-anthropic}}&quot;,&quot;name&quot;:&quot;anthropic local llm-proxy&quot;}}},{&quot;parameters&quot;:{&quot;schemaType&quot;:&quot;manual&quot;,&quot;inputSchema&quot;:&quot;{\&quot;type\&quot;:\&quot;object\&quot;,\&quot;properties\&quot;:{\&