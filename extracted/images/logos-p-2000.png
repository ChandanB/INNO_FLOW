var initialData = {};
try {
  initialData = JSON.parse(htmlDecode(initialDataEl.innerHTML));
} catch (e) {
  console.log("Failed to parse initial data");
}
window.webflowInitialData = initialData;
window.datadogRumConfig = {"applicationId":"f3c57749-9e82-4d88-becf-68d52740251a","clientToken":"pub169e3de286f8f5a3a10c221c89a167d3","sampleRate":100,"replaySampleRate":0,"env":"prod","version":"dev-ef6652ee7a13b35ee88d47cb8092e70626b449cd","allowedTracingOrigins":["https://*.design.webflow.com","https://webflow.com","http://webflow.com","https://www.webflow.com"]};
